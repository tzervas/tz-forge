[project]
name = "{{project}}"
version = "0.1.0"
description = "{{description}}"
readme = "README.md"
license = { text = "MIT" }
authors = [{ name = "Tyler Zervas" }]
requires-python = ">=3.11"
dependencies = [
  "transformers>=4.40",
  "datasets>=2.19",
  "accelerate>=0.30",
  "huggingface-hub>=0.23",
]

[project.optional-dependencies]
dev = ["pytest>=8.0", "ruff>=0.8"]
train = ["peft>=0.11", "trl>=0.9"]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{project_snake}}"]

[tool.ruff]
line-length = 100
target-version = "py311"

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["src"]

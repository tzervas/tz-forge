[project]
name = "{{project}}"
version = "0.1.0"
description = "{{description}}"
readme = "README.md"
license = { text = "MIT" }
requires-python = ">=3.11"
dependencies = []

[project.optional-dependencies]
dev = ["pytest>=8.0", "maturin>=1.7"]

[build-system]
requires = ["maturin>=1.7"]
build-backend = "maturin"

[tool.maturin]
manifest-path = "Cargo.toml"
module-name = "{{project_snake}}"
